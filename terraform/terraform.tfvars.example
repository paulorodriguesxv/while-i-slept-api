project_name = "while-i-slept-api"
environment  = "development"
aws_region   = "us-east-1"
use_localstack = false

dynamodb_billing_mode = "PAY_PER_REQUEST"

summary_queue_visibility_timeout_seconds = 60
summary_queue_message_retention_seconds  = 345600

lambda_api_package_path = "build/api_lambda.zip"
