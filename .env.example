APP_ENV=dev
APP_STORAGE_BACKEND=memory
APP_TIMEZONE_DEFAULT=America/Sao_Paulo

APP_JWT_SECRET=change-me
APP_JWT_ALGORITHM=HS256
APP_ACCESS_TOKEN_TTL_SECONDS=3600
APP_REFRESH_TOKEN_TTL_SECONDS=2592000

APP_FREE_BRIEFING_MAX_ITEMS=5
APP_PREMIUM_BRIEFING_MAX_ITEMS=15

APP_REVENUECAT_WEBHOOK_SECRET=change-me

# Set to true only for local development to allow non-stub id_tokens.
APP_ALLOW_INSECURE_OAUTH_TOKENS=true

# DynamoDB (used when APP_STORAGE_BACKEND=dynamodb)
APP_AWS_REGION=us-east-1
APP_DYNAMODB_ENDPOINT_URL=http://localhost:8000
APP_USERS_TABLE=users
APP_DEVICES_TABLE=devices
APP_BRIEFINGS_TABLE=briefings

# Summarizer worker (SQS)
APP_SUMMARY_JOBS_QUEUE_URL=
APP_SUMMARY_WORKER_VISIBILITY_TIMEOUT_SECONDS=60
APP_SUMMARY_WORKER_WAIT_TIME_SECONDS=20
APP_SUMMARY_WORKER_RETRY_ATTEMPTS=3
APP_SUMMARY_WORKER_RETRY_BACKOFF_SECONDS=0.2
APP_SQS_ENDPOINT_URL=http://localhost:4566
APP_AWS_ENDPOINT_URL=http://localhost:4566
